    def get_results(self) -> list[Seed]: ...

class CheckBatchManager:
    def __init__(self, start_seed:int, end_seed:int, start_star_num:int, end_star_num:int, resource_index:int, galaxy_condition:dict, quick:bool, max_thread:int): ...
